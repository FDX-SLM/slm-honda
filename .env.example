# Copy to `.env` and fill in. `.env` is gitignored and never committed.
# Loaded automatically via python-dotenv; secrets are read from the environment only.

# --- LLM-as-judge API keys (evaluation only; GPT + Gemini, never Claude/DeepSeek) ---
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# --- Experiment tracking (Langfuse: qualitative sample-generation logging) ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# Region host: EU = https://cloud.langfuse.com, US = https://us.cloud.langfuse.com
LANGFUSE_HOST=https://jp.cloud.langfuse.com/

# --- Hugging Face (optional: gated base models / private hub) ---
HF_TOKEN=hf_...
